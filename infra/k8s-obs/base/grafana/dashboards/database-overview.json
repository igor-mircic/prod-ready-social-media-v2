{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Connection saturation (numbackends / max_connections)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"social\"} / on() pg_settings_max_connections",
          "legendFormat": "social",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Connection count vs max_connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"social\"}",
          "legendFormat": "active backends (social)",
          "refId": "A"
        },
        {
          "expr": "pg_settings_max_connections",
          "legendFormat": "max_connections",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Transactions per second (commit + rollback, stacked)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"social\"}[1m])",
          "legendFormat": "commit",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"social\"}[1m])",
          "legendFormat": "rollback",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cache hit ratio (blks_hit / (blks_hit + blks_read))",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "rate(pg_stat_database_blks_hit{datname=\"social\"}[5m]) / (rate(pg_stat_database_blks_hit{datname=\"social\"}[5m]) + rate(pg_stat_database_blks_read{datname=\"social\"}[5m]))",
          "legendFormat": "cache hit ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Tuples affected (inserted / updated / deleted / fetched, stacked)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"social\"}[1m])",
          "legendFormat": "inserted",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"social\"}[1m])",
          "legendFormat": "updated",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"social\"}[1m])",
          "legendFormat": "deleted",
          "refId": "C"
        },
        {
          "expr": "rate(pg_stat_database_tup_fetched{datname=\"social\"}[1m])",
          "legendFormat": "fetched",
          "refId": "D"
        }
      ]
    },
    {
      "id": 6,
      "title": "Deadlock rate (5m window)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": {},
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks{datname=\"social\"}[5m])",
          "legendFormat": "deadlocks/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Database size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"social\"}",
          "legendFormat": "social",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Top-N slow queries (pg_stat_statements, by total exec time)",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #A" }, "properties": [{ "id": "displayName", "value": "calls" }] },
          { "matcher": { "id": "byName", "options": "Value #B" }, "properties": [{ "id": "displayName", "value": "total exec time (ms)" }] },
          { "matcher": { "id": "byName", "options": "Value #C" }, "properties": [{ "id": "displayName", "value": "mean exec time (ms)" }] }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "total exec time (ms)", "desc": true }]
      },
      "targets": [
        {
          "expr": "topk(20, pg_stat_statements_calls{datname=\"social\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "topk(20, pg_stat_statements_total_exec_time{datname=\"social\"})",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "topk(20, pg_stat_statements_mean_exec_time{datname=\"social\"})",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "server": true,
              "queryid": true
            }
          }
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["database", "postgres", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Database overview",
  "uid": "database-overview",
  "version": 1,
  "weekStart": ""
}
