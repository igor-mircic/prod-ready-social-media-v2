{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "title": "Cluster overview",
  "uid": "cluster-overview",
  "tags": ["k3s", "cluster", "otel"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Nodes (kubeletstats + hostmetrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Node CPU utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "k8s_node_cpu_utilization_ratio",
          "legendFormat": "{{k8s_node_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Node memory usage (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "k8s_node_memory_usage_bytes",
          "legendFormat": "{{k8s_node_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Node load average (1m / 5m / 15m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {},
      "targets": [
        { "expr": "system_cpu_load_average_1m", "legendFormat": "{{host_name}} 1m", "refId": "A" },
        { "expr": "system_cpu_load_average_5m", "legendFormat": "{{host_name}} 5m", "refId": "B" },
        { "expr": "system_cpu_load_average_15m", "legendFormat": "{{host_name}} 15m", "refId": "C" }
      ]
    },
    {
      "id": 4,
      "title": "Filesystem usage (bytes) by mountpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "system_filesystem_usage_bytes{state=\"used\"}",
          "legendFormat": "{{host_name}} {{mountpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Node network I/O (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "sum by(host_name, direction) (rate(system_network_io_bytes_total[1m]))",
          "legendFormat": "{{host_name}} {{direction}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Pods (kubeletstats)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "title": "Pod CPU utilization by namespace",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "sum by(k8s_namespace_name) (k8s_pod_cpu_utilization_ratio)",
          "legendFormat": "{{k8s_namespace_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Pod memory working-set by namespace",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "sum by(k8s_namespace_name) (k8s_pod_memory_working_set_bytes)",
          "legendFormat": "{{k8s_namespace_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Top 10 pods by CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "topk(10, k8s_pod_cpu_utilization_ratio)",
          "legendFormat": "{{k8s_namespace_name}}/{{k8s_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Top 10 pods by memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "topk(10, k8s_pod_memory_working_set_bytes)",
          "legendFormat": "{{k8s_namespace_name}}/{{k8s_pod_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "Workloads (k8s_cluster)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "title": "Deployment available",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "k8s_deployment_available",
          "legendFormat": "{{k8s_namespace_name}}/{{k8s_deployment_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "title": "Pod phase distribution by namespace",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "stacking": { "mode": "normal" }, "drawStyle": "bars" }
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "count by(k8s_namespace_name) (k8s_pod_phase == 2)",
          "legendFormat": "Running / {{k8s_namespace_name}}",
          "refId": "A"
        },
        {
          "expr": "count by(k8s_namespace_name) (k8s_pod_phase == 1)",
          "legendFormat": "Pending / {{k8s_namespace_name}}",
          "refId": "B"
        },
        {
          "expr": "count by(k8s_namespace_name) (k8s_pod_phase == 4)",
          "legendFormat": "Failed / {{k8s_namespace_name}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 22,
      "title": "Container restarts (last 1h, expected 0)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "sum by(k8s_namespace_name, k8s_pod_name, k8s_container_name) (increase(k8s_container_restarts[1h]))",
          "legendFormat": "{{k8s_namespace_name}}/{{k8s_pod_name}}/{{k8s_container_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 400,
      "type": "row",
      "title": "Persistent volumes (kubeletstats)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 59 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "title": "Volume capacity (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 60 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "k8s_volume_capacity_bytes",
          "legendFormat": "{{k8s_namespace_name}}/{{k8s_pod_name}}/{{k8s_volume_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 31,
      "title": "Volume used % (per pod-mounted volume)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 60 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "expr": "1 - (k8s_volume_available_bytes / k8s_volume_capacity_bytes)",
          "legendFormat": "{{k8s_namespace_name}}/{{k8s_pod_name}}/{{k8s_volume_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
